PORT=8787

SEELA_BASE_URL=https://www.seela-connect.de
SEELA_USERNAME=dein-benutzername
SEELA_PASSWORD=dein-passwort

# Cron syntax: every 5 minutes by default
CHECK_CRON=*/5 * * * *

# Path to a Firebase Admin SDK service-account JSON file.
# Create it in Firebase Console > Project settings > Service accounts.
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# Alternative for hosted servers: paste the full Firebase Admin SDK JSON into a secret env var.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Alternative for hosted servers: base64 encoded Firebase Admin SDK JSON.
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Optional during testing: send a push even when no previous baseline exists.
SEND_BASELINE_PUSH=false
